	file = {Preprint PDF:/Users/sugarfly/Zotero/storage/CWYQEANH/Lu 等 - 2024 - OmniParser for Pure Vision Based GUI Agent.pdf:application/pdf;Snapshot:/Users/sugarfly/Zotero/storage/5IRU6M8E/2408.html:text/html},
